   "source": [
    "def get_frozen_embeddings(texts, tokenizer, model, max_length=512, batch_size=8,\n",
    "                          pooling=\"cls\"):\n",
    "    \"\"\"\n",
    "    Extract embeddings from a frozen transformer.\n",
    "    pooling: 'cls' (CLS token) or 'mean' (mean of all tokens)\n",
    "    Model weights must be frozen before calling this.\n",
    "    \"\"\"\n",
    "    model.eval()\n",
    "    all_embeddings = []\n",
    "\n",
    "    for i in range(0, len(texts), batch_size):\n",
    "        batch = list(texts[i:i + batch_size])\n",
    "        encoded = tokenizer(\n",
    "            batch, padding=True, truncation=True,\n",
    "            max_length=max_length, return_tensors=\"pt\"\n",
    "        )\n",
    "        encoded = {k: v.to(model.device) for k, v in encoded.items()}\n",
    "\n",
    "        with torch.no_grad():\n",
    "            outputs = model(**encoded)\n",
    "            hidden = outputs.last_hidden_state  # (batch, seq_len, hidden)\n",
    "\n",
    "            if pooling == \"cls\":\n",
    "                emb = hidden[:, 0, :].cpu().numpy()\n",
    "            elif pooling == \"mean\":\n",
    "                mask = encoded[\"attention_mask\"].unsqueeze(-1).float().cpu()\n",
    "                emb = (hidden.cpu() * mask).sum(1) / mask.sum(1)\n",
    "                emb = emb.numpy()\n",
    "\n",
    "        all_embeddings.append(emb)\n",
    "\n",
    "        if (i // batch_size) % 5 == 0:\n",
    "            print(f\"  {min(i + batch_size, len(texts))}/{len(texts)} samples...\")\n",
    "\n",
    "    return np.vstack(all_embeddings)\n",
    "\n",
    "\n",
    "if USE_SEC_BERT:\n",
    "    print(\"Extracting SEC-BERT embeddings (full dataset for CV)...\")\n",
    "    X_sec_bert = get_frozen_embeddings(\n",
    "        X_text.tolist(), sec_tokenizer, sec_model, max_length=512, pooling=\"cls\"\n",
    "    )\n",
    "    np.save(\"X_sec_bert.npy\", X_sec_bert)\n",
    "    print(f\"SEC-BERT embeddings shape: {X_sec_bert.shape}\")\n",
    "else:\n",
    "    print(\"SEC-BERT skipped.\")"
   ]
  },
