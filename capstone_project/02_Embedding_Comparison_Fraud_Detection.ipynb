   "cell_type": "markdown",
   "id": "6eece855",
   "metadata": {},
   "source": [
    "## 7. Embedding 5 — Isolation Forest on SEC-BERT (Unsupervised)\n",
    "\n",
    "**Why unsupervised?**  \n",
    "With 170 samples and class imbalance, supervised models can struggle.  \n",
    "Isolation Forest treats fraud as **anomalies** in the embedding space — no labels needed.\n",
    "\n",
    "> Note: Isolation Forest outputs anomaly scores, not class probabilities.  \n",
    "> We use ROC-AUC and convert predictions for other metrics."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 11,
   "id": "04799b60",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Fraud rate (contamination): 0.500\n",
      "\n",
      "=======================================================\n",
      "  Isolation Forest (SEC-BERT, unsupervised)\n",
      "=======================================================\n",
      "  F1       : 0.4471  (no CV — unsupervised)\n",
      "  Precision: 0.4471\n",
      "  Recall   : 0.4471\n",
      "  ROC-AUC  : 0.4190\n",
      "\n",
      "              precision    recall  f1-score   support\n",
      "\n",
      "   Non-Fraud       0.45      0.45      0.45        85\n",
      "       Fraud       0.45      0.45      0.45        85\n",
      "\n",
      "    accuracy                           0.45       170\n",
      "   macro avg       0.45      0.45      0.45       170\n",
      "weighted avg       0.45      0.45      0.45       170\n",
      "\n"
     ]
    }
   ],
   "source": [
    "if USE_ISOLATION and USE_SEC_BERT:\n",
    "    from sklearn.ensemble import IsolationForest\n",
    "\n",
    "    # Estimate contamination from actual fraud rate\n",
    "    fraud_rate = y.mean()\n",
    "    print(f\"Fraud rate (contamination): {fraud_rate:.3f}\")\n",
    "\n",
    "    iso_forest = IsolationForest(\n",
    "        contamination=fraud_rate,\n",
    "        random_state=RANDOM_STATE,\n",
    "        n_estimators=100\n",
    "    )\n",
    "    iso_forest.fit(X_sec_bert)\n",
    "\n",
    "    # Isolation Forest returns -1 (anomaly=fraud) and 1 (normal)\n",
    "    iso_raw = iso_forest.predict(X_sec_bert)\n",
    "    iso_pred = np.where(iso_raw == -1, 1, 0)  # Convert to fraud=1, non-fraud=0\n",
    "\n",
    "    # Anomaly score: more negative = more anomalous\n",
    "    iso_scores = -iso_forest.score_samples(X_sec_bert)  # flip sign so higher = more fraud\n",
    "\n",
    "    iso_f1  = f1_score(y, iso_pred, zero_division=0)\n",
    "    iso_auc = roc_auc_score(y, iso_scores)\n",
    "    iso_prec = precision_score(y, iso_pred, zero_division=0)\n",
    "    iso_rec  = recall_score(y, iso_pred, zero_division=0)\n",
    "    iso_acc  = accuracy_score(y, iso_pred)\n",
    "\n",
    "    res = {\n",
    "        \"model\": \"Isolation Forest (SEC-BERT, unsupervised)\",\n",
    "        \"f1_mean\": iso_f1, \"f1_std\": 0.0,\n",
    "        \"precision_mean\": iso_prec, \"recall_mean\": iso_rec,\n",
    "        \"roc_auc_mean\": iso_auc, \"accuracy_mean\": iso_acc\n",
    "    }\n",
    "    results_list.append(res)\n",
    "    cv_preds[\"Isolation Forest\"] = iso_pred\n",
    "\n",
    "    print(f\"\\n{'='*55}\")\n",
    "    print(f\"  Isolation Forest (SEC-BERT, unsupervised)\")\n",
    "    print(f\"{'='*55}\")\n",
    "    print(f\"  F1       : {iso_f1:.4f}  (no CV — unsupervised)\")\n",
    "    print(f\"  Precision: {iso_prec:.4f}\")\n",
    "    print(f\"  Recall   : {iso_rec:.4f}\")\n",
    "    print(f\"  ROC-AUC  : {iso_auc:.4f}\")\n",
    "    print()\n",
    "    print(classification_report(y, iso_pred, target_names=[\"Non-Fraud\", \"Fraud\"]))\n",
    "elif USE_ISOLATION and not USE_SEC_BERT:\n",
    "    print(\"Isolation Forest skipped: requires SEC-BERT. Set USE_SEC_BERT = True.\")\n",
    "else:\n",
    "    print(\"Isolation Forest skipped.\")"
   ]
  },
